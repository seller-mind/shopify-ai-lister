  },
  "devDependencies": {
    "@remix-run/dev": "2.15.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "typescript": "5.7.3",
    "vite": "5.4.14"
